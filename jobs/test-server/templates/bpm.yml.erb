processes:
- name: test-server
  executable: /var/vcap/packages/test-server/bin/test-server
  args:
    - --port
    - 1337
  env:
    BPM: SWEET
  limits:
    memory: 743M
    open_files: 2444
    processes: 503
    core_file_size: 1073741824
  ephemeral_disk: true
  persistent_disk: true
  additional_volumes:
  - path: /var/vcap/data/shared
  unsafe:
    unrestricted_volumes:
    - path: /dev/log

- name: alt-test-server
  executable: /var/vcap/packages/test-server/bin/test-server
  args:
    - --port
    - 1338
    - --ignore-signals
  env:
    BPM: CONTAINED

- name: privileged-observer
  executable: /var/vcap/packages/test-server/bin/test-server
  args:
    - --port
    - 1339
  env:
    BPM: OBSERVER
  unsafe:
    privileged: true
    host_pid_namespace: true
    unrestricted_volumes:
    - path: /sys/fs/cgroup
